    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-page-stack": "^3.3.0",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.105.0"
